# ─── Base de datos ────────────────────────────────────────────────────────────
# Supabase (producción) — obtener desde dashboard → Connect → ORMs
# Transaction pooler (queries normales de la app y agentes Python)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (migraciones, prisma db push)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

APP_ENV="development"

# ─── IA ───────────────────────────────────────────────────────────────────────
# Estas son el FALLBACK global. Cada cliente puede cargar su propia API key y
# modelo desde el dashboard (/clients), que tienen prioridad sobre estas.
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324:free"
# Audit GEO multi-modelo (opcional, separar por comas)
GEO_AUDIT_MODELS=""

# D-ID (Generación de videos con Avatares)
# Dejar vacío o "mock" para usar el simulador local de renderizado gratuito sin API
DID_API_KEY=""

# Render local comercial de videos con avatar
# local = Edge-TTS + Wav2Lip/FFmpeg local. did = fallback externo con D-ID.
VIDEO_RENDER_PROVIDER="local"
LOCAL_AVATAR_MODE="wav2lip"
LOCAL_AVATAR_FALLBACK_MODE="loop"
PYTHON_BIN="python"
LOCAL_AVATAR_TEMPLATE_DIR="assets/avatar-templates"
LOCAL_VIDEO_OUTPUT_DIR="public/videos"
WAV2LIP_INFERENCE_SCRIPT="models/wav2lip/inference.py"
WAV2LIP_MODEL_PATH="models/wav2lip/wav2lip_gan.pth"

# ─── Autenticación del dashboard ─────────────────────────────────────────────
AUTH_PASSWORD=""
AUTH_SECRET=""

# ─── NSTBrowser (automatización de navegador) ─────────────────────────────────
NSTBROWSER_API_KEY=""

# ─── Cuentas sociales — quinteto de personas ─────────────────────────────────
