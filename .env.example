# ─── Base de datos ────────────────────────────────────────────────────────────
# Supabase (producción recomendado) — obtener desde dashboard → Connect → ORMs
# Transaction pooler (queries normales de la app)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (migraciones y prisma db push)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# SQLite local (desarrollo sin Supabase)
# DATABASE_URL="file:./dev.db"

APP_ENV="development"

# ─── IA ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324:free"

# ─── Autenticación del dashboard ─────────────────────────────────────────────
# AUTH_PASSWORD: contraseña que ingresa el operador en la pantalla de login
AUTH_PASSWORD=""
# AUTH_SECRET: token interno guardado en la cookie de sesión (string aleatorio largo)
AUTH_SECRET=""

# ─── Dolphin Anty (automatización de navegador) ───────────────────────────────
DOLPHIN_API_BASE="http://localhost:3001/v1.0"
DOLPHIN_CLOUD_API_BASE="https://dolphin-anty-api.com"
DOLPHIN_API_TOKEN=""

# ─── Cuentas sociales — quinteto de personas ─────────────────────────────────
# Nunca commitear valores reales. Solo cuentas propias/autorizadas.
APOSTOLES_PROFE_USER=""
APOSTOLES_PROFE_PASSWORD=""

APOSTOLES_PRODUCTOR_USER=""
APOSTOLES_PRODUCTOR_PASSWORD=""

APOSTOLES_BATERISTA_USER=""
APOSTOLES_BATERISTA_PASSWORD=""

APOSTOLES_KRESSMER_USER=""
APOSTOLES_KRESSMER_PASSWORD=""

APOSTOLES_CAZADOR_USER=""
APOSTOLES_CAZADOR_PASSWORD=""
