# ─── Base de datos ────────────────────────────────────────────────────────────
# Supabase (producción) — obtener desde dashboard → Connect → ORMs
# Transaction pooler (queries normales de la app y agentes Python)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (migraciones, prisma db push)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

APP_ENV="development"

# ─── IA ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="deepseek/deepseek-chat-v3-0324:free"
# Audit GEO multi-modelo (opcional, separar por comas)
GEO_AUDIT_MODELS=""

# ─── Autenticación del dashboard ─────────────────────────────────────────────
AUTH_PASSWORD=""
AUTH_SECRET=""

# ─── NSTBrowser (automatización de navegador) ─────────────────────────────────
NSTBROWSER_API_KEY=""

# ─── Cuentas sociales — quinteto de personas ─────────────────────────────────
# Nunca commitear valores reales. Solo cuentas propias/autorizadas.
APOSTOLES_PROFE_USER=""
APOSTOLES_PROFE_PASSWORD=""
APOSTOLES_PRODUCTOR_USER=""
APOSTOLES_PRODUCTOR_PASSWORD=""
APOSTOLES_BATERISTA_USER=""
APOSTOLES_BATERISTA_PASSWORD=""
APOSTOLES_KRESSMER_USER=""
APOSTOLES_KRESSMER_PASSWORD=""
APOSTOLES_CAZADOR_USER=""
APOSTOLES_CAZADOR_PASSWORD=""

# ─── Agent relay (acceso remoto) ──────────────────────────────────────────────
AGENT_RELAY_PORT=4242
AGENT_RELAY_TOKEN=""
AGENT_RELAY_URL=""

# ─── Nurturing por email (SMTP) ───────────────────────────────────────────────
NURTURE_SMTP_HOST=""
NURTURE_SMTP_PORT=465
NURTURE_SMTP_USER=""
NURTURE_SMTP_PASS=""
NURTURE_FROM_EMAIL="lab@pcmidicenter.com"
NURTURE_FROM_NAME="Bruno de PC MIDI Labs"
NURTURE_UNSUBSCRIBE_BASE_URL="https://blog.pcmidicenter.com/api/unsubscribe/"
NURTURE_TRACK_BASE_URL="https://blog.pcmidicenter.com"
NURTURE_UNSUBSCRIBE_SECRET=""
NURTURE_CRON_SECRET=""

# ─── Deploy landings estáticas ────────────────────────────────────────────────
LANDING_BASE_URL="https://blog.pcmidicenter.com"
DEPLOY_TARGET="vercel"
VERCEL_TOKEN=""
VERCEL_SCOPE=""

# ─── APIs de investigación (opcionales) ───────────────────────────────────────
SERPER_API_KEY=""
