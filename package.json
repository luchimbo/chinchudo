{
  "name": "pcmidi-suite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:server": "node scripts/dev-server.mjs",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:sync": "node scripts/sync-sqlite.mjs",
    "db:push": "node scripts/db-apply-diff.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "agents:listen": "python agents/orchestrator.py listen",
    "agents:draft": "python agents/orchestrator.py draft",
    "agents:backfill": "npx tsx scripts/backfill-personas.mts",
    "db:seed-sources": "npx tsx scripts/seed-monitored-sources.mts",
    "agents:export": "python agents/orchestrator.py export",
    "agents:daily": "python agents/orchestrator.py daily",
    "agents:monitor": "python agents/orchestrator.py monitor",
    "agents:healthcheck": "python agents/orchestrator.py healthcheck",
    "agents:publish": "node scripts/publish-response.mjs",
    "agents:research": "python agents/orchestrator.py research",
    "agents:generate": "python agents/orchestrator.py generate",
    "agents:build-landings": "python agents/orchestrator.py build-landings",
    "agents:nurture": "python agents/orchestrator.py nurture",
    "agents:distribution": "python agents/orchestrator.py distribution generate",
    "agents:geo-audit": "python agents/orchestrator.py geo-audit",
    "agents:conversion": "python agents/orchestrator.py conversion",
    "db:backup": "node scripts/backup-db.mjs",
    "db:supabase-push": "prisma db push",
    "relay": "node scripts/agent-relay.mjs",
    "relay:start": "node scripts/start-relay.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
