generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OpportunityStatus {
  NEW
  NEEDS_REVIEW
  DRAFTED
  APPROVED
  PUBLISHED
  DISCARDED
  FOLLOW_UP
  CONVERTED
}

enum OpportunityPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportunityIntent {
  PURCHASE_QUESTION
  TECHNICAL_QUESTION
  PRICE_QUESTION
  WARRANTY_QUESTION
  COMPARISON
  COMPLAINT
  COMPETITOR_MENTION
  GENERAL_DISCUSSION
}

enum ResponseVariantType {
  SHORT
  TECHNICAL
  CONVERSATIONAL
}

// ─── Multi-Cliente ─────────────────────────────────────────────────────────────

model Client {
  id                  String            @id @default(cuid())
  name                String            @unique
  slug                String            @unique
  description         String            @default("")
  domainKeywords      String            @default("[]")
  domainExclusions    String            @default("[]")
  autoPublish         Boolean           @default(false)
  autoApprove         Boolean           @default(false)
  active              Boolean           @default(true)
  openrouterApiKey    String            @default("")
  openrouterModel     String            @default("")
  // Branding / landings
  storeUrl            String            @default("")
  blogBaseUrl         String            @default("")
  labName             String            @default("")
  logoUrl             String            @default("")
  // Email / nurturing (Fase 2)
  fromName            String            @default("")
  fromEmail           String            @default("")
  smtpHost            String            @default("")
  smtpPort            Int               @default(465)
  smtpUser            String            @default("")
  smtpPass            String            @default("")
  unsubscribeBaseUrl  String            @default("")
  trackBaseUrl        String            @default("")
  // GEO (Fase 3)
  geoBrandPatterns    Json              @default("[]")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  brands              Brand[]
  personas            Persona[]
  monitoredSources    MonitoredSource[]
  catalogRules        CatalogRule[]
  landingCategories   LandingCategory[]
  landingProducts     LandingProduct[]
  seedTopics          SeedTopic[]
  landings            Landing[]
  leadMagnets         LeadMagnet[]
  leads               Lead[]
  nurtureSteps        NurtureStep[]
  distributionPieces  DistributionPiece[]
  geoAudits           GeoAudit[]
  trackingEvents      TrackingEvent[]
}

model CatalogRule {
  id        String   @id @default(cuid())
  clientId  String
  category  String
  keywords  String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, category])
}

model PersonaRule {
  id        String   @id @default(cuid())
  personaId String
  weight    Int      @default(3)
  trigger   String
  pattern   String
  reason    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

// ─── Modelos de Negocio ───────────────────────────────────────────────────────

model Brand {
  id              String        @id @default(cuid())
  clientId        String?
  name            String
  positioning     String
  tone            String
  allowedClaims   String        @default("")
  forbiddenClaims String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client?       @relation(fields: [clientId], references: [id])
  opportunities   Opportunity[]
  products        Product[]
  responses       Response[]

  @@unique([clientId, name])
}

model Product {
  id             String        @id @default(cuid())
  brandId        String
  name           String
  category       String
  description    String
  technicalSpecs String        @default("")
  useCases       String        @default("")
  warrantyNotes  String        @default("")
  stockStatus    String        @default("Por confirmar")
  priceRange     String        @default("Por confirmar")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  opportunities  Opportunity[]
  brand          Brand         @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, name])
}

model Persona {
  id               String        @id @default(cuid())
  clientId         String?
  name             String
  role             String
  tone             String
  goals            String
  preferredLength  String
  allowedPhrases   String        @default("")
  forbiddenPhrases String        @default("")
  goodExamples     String        @default("")
  badExamples      String        @default("")
  angle            String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  client           Client?       @relation(fields: [clientId], references: [id])
  responses        Response[]
  rules            PersonaRule[]

  @@unique([clientId, name])
}

model Channel {
  id                 String        @id @default(cuid())
  name               String        @unique
  type               String
  baseUrl            String
  responseStyleNotes String
  opportunities      Opportunity[]
}

model Opportunity {
  id                String              @id @default(cuid())
  channelId         String
  sourceUrl         String
  sourceAuthor      String              @default("")
  sourceText        String
  detectedBrandId   String?
  detectedProductId String?
  detectedIntent    OpportunityIntent   @default(GENERAL_DISCUSSION)
  priority          OpportunityPriority @default(MEDIUM)
  status            OpportunityStatus   @default(NEW)
  notes             String              @default("")
  monitoredSourceId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  channel           Channel             @relation(fields: [channelId], references: [id])
  detectedBrand     Brand?              @relation(fields: [detectedBrandId], references: [id])
  detectedProduct   Product?            @relation(fields: [detectedProductId], references: [id])
  monitoredSource   MonitoredSource?    @relation(fields: [monitoredSourceId], references: [id])
  publishingLogs    PublishingLog[]
  responses         Response[]
  landings          Landing[]
  distribution      DistributionPiece[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model Response {
  id            String              @id @default(cuid())
  opportunityId String
  personaId     String
  brandId       String
  variantType   ResponseVariantType
  draftText     String
  editedText    String              @default("")
  riskNotes     String              @default("")
  approvedBy    String              @default("")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  publishingLog PublishingLog?
  brand         Brand               @relation(fields: [brandId], references: [id])
  opportunity   Opportunity         @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  persona       Persona             @relation(fields: [personaId], references: [id])
}

model PublishingLog {
  id             String      @id @default(cuid())
  opportunityId  String
  responseId     String      @unique
  publishedUrl   String      @default("")
  publishedAt    DateTime    @default(now())
  publishedBy    String      @default("Fede")
  result         String      @default("no_reply")
  followUpNeeded Boolean     @default(false)
  createdAt      DateTime    @default(now())
  account        String      @default("")
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  response       Response    @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id         String   @id @default(cuid())
  clientId   String?
  brandId    String?
  productId  String?
  topic      String
  content    String
  source     String   @default("manual")
  confidence String   @default("medium")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Objection {
  id                String   @id @default(cuid())
  clientId          String?
  brandId           String?
  productId         String?
  objection         String
  recommendedAnswer String
  personaNotes      String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model MonitoredSource {
  id            String        @id @default(cuid())
  clientId      String?
  label         String        @unique
  channel       String
  query         String
  account       String        @default("")
  limit         Int           @default(5)
  active        Boolean       @default(true)
  lastRunAt     DateTime?
  lastCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        Client?       @relation(fields: [clientId], references: [id])
  opportunities Opportunity[]
}

model PromptVersion {
  id                 String   @id @default(cuid())
  name               String
  version            String
  systemPrompt       String
  userPromptTemplate String
  active             Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([name, version])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  event     String
  message   String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([level])
  @@index([event])
  @@index([createdAt])
}

// ─── Módulo de Landings SEO (ex-AgentesGuille) ───────────────────────────────

enum LandingStatus {
  DRAFT
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum LeadMagnetType {
  CHECKLIST
  GUIA
  COMPARATIVA
  PLANTILLA
  PRESET
}

enum NurtureStepStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum DistributionChannel {
  REDDIT
  LINKEDIN
  TWITTER
  FACEBOOK
  INSTAGRAM
  YOUTUBE
  NEWSLETTER
  FORUM
}

enum DistributionStatus {
  NEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

model LeadMagnet {
  id        String         @id @default(cuid())
  clientId  String?
  tipo      LeadMagnetType
  titulo    String
  contenido String
  slug      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  client    Client?        @relation(fields: [clientId], references: [id])
  landings  Landing[]
  leads     Lead[]

  @@index([clientId])
}

model Landing {
  id             String        @id @default(cuid())
  clientId       String?
  slug           String        @unique
  keyword        String
  intent         String        @default("")
  titulo         String        @default("")
  htmlContent    String
  seoTitle       String        @default("")
  seoDescription String        @default("")
  status         LandingStatus @default(DRAFT)
  publishedAt    DateTime?
  opportunityId  String?
  leadMagnetId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  client         Client?       @relation(fields: [clientId], references: [id])
  opportunity    Opportunity?  @relation(fields: [opportunityId], references: [id])
  leadMagnet     LeadMagnet?   @relation(fields: [leadMagnetId], references: [id])
  leads          Lead[]
  distribution   DistributionPiece[]
  trackingEvents TrackingEvent[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model Lead {
  id           String        @id @default(cuid())
  clientId     String?
  email        String
  nombre       String        @default("")
  slug         String
  keyword      String        @default("")
  leadMagnetId String?
  consent      Boolean       @default(false)
  createdAt    DateTime      @default(now())
  landingId    String?
  client       Client?       @relation(fields: [clientId], references: [id])
  landing      Landing?      @relation(fields: [landingId], references: [id])
  leadMagnet   LeadMagnet?   @relation(fields: [leadMagnetId], references: [id])
  nurtureSteps NurtureStep[]

  @@index([clientId])
  @@index([email])
  @@index([slug])
  @@index([createdAt])
}

model NurtureStep {
  id          String            @id @default(cuid())
  clientId    String?
  leadId      String
  stepDay     Int
  subject     String            @default("")
  bodyHtml    String            @default("")
  status      NurtureStepStatus @default(PENDING)
  scheduledAt DateTime
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  createdAt   DateTime          @default(now())
  client      Client?           @relation(fields: [clientId], references: [id])
  lead        Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([scheduledAt])
}

model DistributionPiece {
  id            String              @id @default(cuid())
  clientId      String?
  canal         DistributionChannel
  contenido     String
  status        DistributionStatus  @default(NEW)
  scheduledAt   DateTime?
  publishedAt   DateTime?
  publishedUrl  String?
  landingId     String?
  opportunityId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  client        Client?             @relation(fields: [clientId], references: [id])
  landing       Landing?            @relation(fields: [landingId], references: [id])
  opportunity   Opportunity?        @relation(fields: [opportunityId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([canal])
  @@index([scheduledAt])
}

model GeoAudit {
  id                String   @id @default(cuid())
  clientId          String?
  prompt            String
  modeloIA          String
  score             Int
  competidores      Json     @default("[]")
  gapsSugeridos     Json     @default("[]")
  respuestaCompleta String   @default("")
  createdAt         DateTime @default(now())
  client            Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([createdAt])
  @@index([score])
}

model TrackingEvent {
  id        String   @id @default(cuid())
  clientId  String?
  eventType String
  slug      String
  referrer  String   @default("")
  meta      Json     @default("{}")
  landingId String?
  createdAt DateTime @default(now())
  client    Client?  @relation(fields: [clientId], references: [id])
  landing   Landing? @relation(fields: [landingId], references: [id])

  @@index([clientId])
  @@index([slug])
  @@index([eventType])
  @@index([createdAt])
}

// ─── Catálogo de Landings (Pipeline B, multi-cliente) ────────────────────────

model LandingCategory {
  id          String   @id @default(cuid())
  clientId    String
  key         String
  name        String
  url         String   @default("")
  description String   @default("")
  keywords    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, key])
  @@index([clientId])
}

model LandingProduct {
  id          String   @id @default(cuid())
  clientId    String
  externalId  String
  name        String
  brand       String   @default("")
  model       String   @default("")
  categoryKey String   @default("")
  url         String   @default("")
  useText     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, externalId])
  @@index([clientId])
  @@index([categoryKey])
}

model SeedTopic {
  id                  String   @id @default(cuid())
  clientId            String
  keyword             String
  intent              String   @default("")
  suggestedCategories Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([keyword])
}

